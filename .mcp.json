{
  "mcpServers": {
    "urc-coordination": {
      "command": ".venv/bin/python3",
      "args": ["urc/core/server.py"],
      "env": {
        "PYTHONPATH": "."
      }
    },
    "codex": {
      "command": "codex",
      "args": ["mcp-server"],
      "env": {
        "MCP_TOOL_TIMEOUT": "120000"
      }
    }
  }
}
